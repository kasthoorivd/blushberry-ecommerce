<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Your Cart – Blush Berry</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,400&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <style>
    *{box-sizing:border-box;margin:0;padding:0;}
    body{font-family:'Poppins',sans-serif;background:#fff;color:#333;overflow-x:hidden;}
    a{text-decoration:none;color:inherit;}

    /* ── Page header ── */
    .page-header{background:linear-gradient(110deg,#fff8f9 55%,#fce8ed 100%);padding:32px 48px 24px;}
    .page-header p{font-size:11px;letter-spacing:3px;text-transform:uppercase;color:#c0415a;margin-bottom:6px;}
    .page-header h1{font-family:'Playfair Display',serif;font-size:32px;font-weight:900;color:#1a1a2e;}
    .breadcrumb{font-size:12px;color:#aaa;margin-top:8px;display:flex;gap:6px;align-items:center;}
    .breadcrumb a{color:#c0415a;}
    .breadcrumb-sep{color:#ddd;}

    /* ── Layout ── */
    .cart-wrap{display:flex;gap:32px;padding:36px 48px 60px;align-items:flex-start;}
    .cart-items{flex:1;}
    .cart-summary{width:320px;min-width:320px;position:sticky;top:20px;}

    /* ── Alert banners ── */
    .alert{padding:12px 16px;border-radius:8px;font-size:13px;margin-bottom:20px;display:flex;align-items:flex-start;gap:10px;}
    .alert-warn{background:#fff8e6;border:1px solid #ffe0a0;color:#b07000;}
    .alert-danger{background:#fce8e8;border:1px solid #f0c0c0;color:#c03030;}

    /* ── Cart item card ── */
    .cart-item{display:flex;gap:18px;padding:20px;border:1px solid #f0e6e8;border-radius:12px;background:#fff;margin-bottom:14px;transition:box-shadow .2s;position:relative;}
    .cart-item:hover{box-shadow:0 4px 20px rgba(192,65,90,0.08);}
    .cart-item.out-of-stock{opacity:.7;}
    .cart-item.out-of-stock .item-name{color:#aaa;}
    .item-img{width:90px;height:90px;border-radius:8px;overflow:hidden;background:linear-gradient(135deg,#fff5f7,#fce8ed);flex-shrink:0;}
    .item-img img{width:100%;height:100%;object-fit:cover;}
    .item-details{flex:1;}
    .item-brand{font-size:9px;letter-spacing:1.5px;text-transform:uppercase;color:#bbb;margin-bottom:3px;}
    .item-name{font-size:14px;font-weight:500;color:#1a1a2e;margin-bottom:4px;line-height:1.3;}
    .item-shade{font-size:11px;color:#c0415a;margin-bottom:8px;}
    .item-price-row{display:flex;align-items:center;gap:8px;margin-bottom:10px;}
    .item-price{font-size:15px;font-weight:700;color:#c0415a;}
    .item-orig{font-size:12px;color:#ccc;text-decoration:line-through;}
    .item-subtotal{font-size:12px;color:#aaa;}

    /* stock warning on item */
    .item-stock-warn{font-size:11px;color:#e8a826;margin-bottom:8px;}
    .item-out-tag{display:inline-block;background:#fce8e8;color:#e05555;font-size:10px;padding:2px 8px;border-radius:10px;margin-bottom:8px;}

    /* ── Qty controls ── */
    .qty-row{display:flex;align-items:center;gap:10px;flex-wrap:wrap;}
    .qty-wrap{display:flex;align-items:center;border:1px solid #e8d8dc;border-radius:6px;overflow:hidden;}
    .qty-btn{width:32px;height:34px;background:#fffafb;border:none;font-size:16px;cursor:pointer;color:#c0415a;display:flex;align-items:center;justify-content:center;transition:background .2s;}
    .qty-btn:hover{background:#fce8ed;}
    .qty-btn:disabled{color:#ccc;cursor:not-allowed;background:#fafafa;}
    .qty-num{width:40px;height:34px;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:500;color:#1a1a2e;border-left:1px solid #e8d8dc;border-right:1px solid #e8d8dc;}
    .btn-remove{background:none;border:none;font-size:12px;color:#ccc;cursor:pointer;padding:4px 8px;border-radius:4px;transition:color .2s;}
    .btn-remove:hover{color:#e05555;background:#fce8e8;}

    /* ── Summary card ── */
    .summary-card{background:#fffafb;border:1px solid #f0e6e8;border-radius:12px;padding:24px;}
    .summary-title{font-family:'Playfair Display',serif;font-size:20px;font-weight:700;color:#1a1a2e;margin-bottom:20px;}
    .summary-row{display:flex;justify-content:space-between;align-items:center;font-size:13px;color:#666;margin-bottom:12px;}
    .summary-row.total{font-size:16px;font-weight:700;color:#1a1a2e;border-top:1px solid #f0e6e8;padding-top:14px;margin-top:4px;}
    .summary-row span:last-child{font-weight:600;color:#c0415a;}
    .summary-row.total span:last-child{font-size:18px;}
    .btn-checkout{width:100%;padding:14px;background:#c0415a;color:#fff;border:none;border-radius:6px;font-size:13px;font-weight:600;letter-spacing:1px;text-transform:uppercase;cursor:pointer;transition:background .2s;margin-top:16px;}
    .btn-checkout:hover{background:#a33049;}
    .btn-checkout:disabled{background:#ccc;cursor:not-allowed;}
    .checkout-note{font-size:11px;color:#aaa;text-align:center;margin-top:10px;line-height:1.5;}
    .btn-continue{display:block;text-align:center;margin-top:12px;font-size:12px;color:#c0415a;border-bottom:1px solid #c0415a;width:fit-content;margin-left:auto;margin-right:auto;padding-bottom:2px;}

    /* ── Empty cart ── */
    .empty-cart{text-align:center;padding:80px 20px;}
    .empty-cart .icon{font-size:60px;margin-bottom:16px;}
    .empty-cart h3{font-family:'Playfair Display',serif;font-size:24px;color:#1a1a2e;margin-bottom:8px;}
    .empty-cart p{font-size:13px;color:#aaa;margin-bottom:24px;}
    .empty-cart a{display:inline-block;padding:12px 32px;background:#c0415a;color:#fff;border-radius:4px;font-size:12px;font-weight:600;letter-spacing:1px;text-transform:uppercase;}

    /* ── Toast ── */
    .toast{position:fixed;bottom:28px;right:28px;padding:12px 22px;border-radius:6px;font-size:13px;font-weight:500;color:#fff;z-index:9999;opacity:0;transform:translateY(10px);transition:all .3s ease;pointer-events:none;max-width:320px;}
    .toast.show{opacity:1;transform:translateY(0);}
    .toast.success{background:#22b573;}
    .toast.error{background:#e05555;}
    .toast.warn{background:#e8a826;}

    /* ── Responsive ── */
    @media(max-width:860px){
      .cart-wrap{flex-direction:column;padding:20px;}
      .cart-summary{width:100%;min-width:unset;position:static;}
      .page-header{padding:24px 20px 18px;}
    }
  </style>
</head>
<body>
  <%- include('../partials/user/header') %>

  <!-- Page header -->
  <div class="page-header">
    <p>Blush Berry</p>
    <h1>Your Cart</h1>
    <div class="breadcrumb">
      <a href="/">Home</a><span class="breadcrumb-sep">›</span>
      <a href="/products">Shop</a><span class="breadcrumb-sep">›</span>
      <span style="color:#555;">Cart</span>
    </div>
  </div>

  <% if(items.length === 0){ %>
  <!-- ── Empty cart ── -->
  <div class="empty-cart">
    <div class="icon">🛍️</div>
    <h3>Your cart is empty</h3>
    <p>Looks like you haven't added anything yet.</p>
    <a href="/products">Start Shopping</a>
  </div>

  <% } else { %>
  <div class="cart-wrap">

    <!-- ══════════════════════
         LEFT — Items
    ══════════════════════ -->
    <div class="cart-items">

      <!-- Removed products alert -->
      <% if(removedNames && removedNames.length){ %>
      <div class="alert alert-warn">
        <span>⚠️</span>
        <span><strong><%= removedNames.join(', ') %></strong> <%= removedNames.length > 1 ? 'were' : 'was' %> removed because <%= removedNames.length > 1 ? 'they are' : 'it is' %> no longer available.</span>
      </div>
      <% } %>

      <!-- Out of stock alert -->
      <% if(hasOutOfStock){ %>
      <div class="alert alert-danger">
        <span>🚫</span>
        <span>Some items are out of stock. Please remove them before checkout.</span>
      </div>
      <% } %>

      <!-- Items -->
      <% items.forEach(item => { %>
      <div class="cart-item <%= !item.inStock ? 'out-of-stock' : '' %>" id="item-<%= item._id %>">

        <!-- Image -->
        <div class="item-img" onclick="window.location='/products/<%= item.product._id %>'" style="cursor:pointer;">
          <% if(item.product.images && item.product.images[0]){ %>
            <img src="<%= item.product.images[0] %>" alt="<%= item.product.name %>">
          <% } else { %>
            <div style="display:flex;align-items:center;justify-content:center;height:100%;font-size:28px;">💄</div>
          <% } %>
        </div>

        <!-- Details -->
        <div class="item-details">
          <p class="item-brand">Blush Berry</p>
          <p class="item-name"><%= item.product.name %></p>
          <% if(item.shade){ %>
          <p class="item-shade">Shade: <%= item.shade %></p>
          <% } %>

          <!-- Price -->
          <div class="item-price-row">
            <span class="item-price">₹<%= item.currentPrice.toFixed(2) %></span>
            <% if(item.product.offer > 0){ %>
              <span class="item-orig">₹<%= (item.variant.varientPrice).toFixed(2) %></span>
            <% } %>
            <span class="item-subtotal">× <%= item.effectiveQty %> = ₹<%= (item.currentPrice * item.effectiveQty).toFixed(2) %></span>
          </div>

          <!-- Stock warnings -->
          <% if(!item.inStock){ %>
            <span class="item-out-tag">Out of Stock</span>
          <% } else if(item.qtyExceedsStock){ %>
            <p class="item-stock-warn">⚠ Only <%= item.stockAvailable %> available — quantity adjusted</p>
          <% } else if(item.qtyExceedsMax){ %>
            <p class="item-stock-warn">⚠ Maximum <%= maxQty %> units per item</p>
          <% } else if(item.stockAvailable <= 5){ %>
            <p class="item-stock-warn">⚠ Only <%= item.stockAvailable %> left in stock</p>
          <% } %>

          <!-- Qty controls -->
          <div class="qty-row">
            <% if(item.inStock){ %>
            <div class="qty-wrap">
              <button class="qty-btn"
                onclick="updateQty('<%= item._id %>', 'decrement')"
                <%= item.effectiveQty <= 1 ? '' : '' %>>−</button>
              <div class="qty-num" id="qty-<%= item._id %>"><%= item.effectiveQty %></div>
              <button class="qty-btn"
                onclick="updateQty('<%= item._id %>', 'increment')"
                <%= (item.effectiveQty >= maxQty || item.effectiveQty >= item.stockAvailable) ? 'disabled' : '' %>>+</button>
            </div>
            <% } %>
            <button class="btn-remove" onclick="removeItem('<%= item._id %>')">🗑 Remove</button>
          </div>
        </div>

      </div>
      <% }) %>

    </div>

    <!-- ══════════════════════
         RIGHT — Summary
    ══════════════════════ -->
    <div class="cart-summary">
      <div class="summary-card">
        <h3 class="summary-title">Order Summary</h3>

        <div class="summary-row">
          <span>Items (<%= items.length %>)</span>
          <span>₹<%= subtotal.toFixed(2) %></span>
        </div>
        <div class="summary-row">
          <span>Shipping</span>
          <span style="color:#22b573;font-weight:600;">Free</span>
        </div>
        <div class="summary-row total">
          <span>Total</span>
          <span id="cartTotal">₹<%= subtotal.toFixed(2) %></span>
        </div>

        <!-- Checkout button -->
        <% if(canCheckout){ %>
        <button class="btn-checkout" onclick="window.location='/checkout'">
          Proceed to Checkout →
        </button>
        <% } else { %>
        <button class="btn-checkout" disabled>
          <% if(hasOutOfStock){ %>Remove Out-of-Stock Items First
          <% } else if(items.length === 0){ %>Cart is Empty
          <% } else { %>Fix Cart Issues First<% } %>
        </button>
        <% } %>

        <p class="checkout-note">
          <% if(!canCheckout && hasOutOfStock){ %>
            Remove out-of-stock items to continue.
          <% } else { %>
            Free shipping on all orders. Easy 30-day returns.
          <% } %>
        </p>

        <a href="/products" class="btn-continue">← Continue Shopping</a>
      </div>
    </div>

  </div>
  <% } %>

  <!-- Coupon Section -->
<div style="background:#fff;border:1px solid #f2e6e9;border-radius:12px;padding:20px 24px;margin-top:16px;">
  <h3 style="font-family:'Poppins',sans-serif;font-size:14px;font-weight:600;color:#1a1a2e;margin:0 0 14px;">Apply Coupon</h3>
  
  <div style="display:flex;gap:10px;">
    <input 
      type="text" 
      placeholder="Enter coupon code"
      style="flex:1;padding:10px 14px;border:1px solid #e8c8d0;border-radius:8px;font-size:13px;font-family:'Poppins',sans-serif;outline:none;color:#1a1a2e;"
    >
    <button 
      style="background:#c0415a;color:#fff;border:none;padding:10px 20px;border-radius:8px;font-size:13px;font-weight:600;font-family:'Poppins',sans-serif;cursor:pointer;">
      Apply
    </button>
  </div>

  <!-- Success message (hidden for now) -->
  <p style="display:none;margin:10px 0 0;font-size:12px;color:#2e7d32;font-family:'Poppins',sans-serif;">
    ✓ Coupon applied! ₹100 off
  </p>

  <!-- Error message (hidden for now) -->
  <p style="display:none;margin:10px 0 0;font-size:12px;color:#c0415a;font-family:'Poppins',sans-serif;">
    ✗ Invalid coupon code
  </p>
</div>

  <!-- Toast -->
  <div class="toast" id="toast"></div>

  <%- include('../partials/user/footer') %>

  <script>
    function showToast(msg, type = 'success') {
      const t = document.getElementById('toast')
      t.textContent = msg
      t.className = `toast ${type} show`
      setTimeout(() => t.classList.remove('show'), 3000)
    }

    // ── Update quantity (increment / decrement) ──
    function updateQty(itemId, action) {
      fetch('/cart/update', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ itemId, action })
      })
      .then(r => r.json())
      .then(data => {
        if (data.success) {
          if (data.removed) {
            // item was removed (decremented below 1 or product gone)
            document.getElementById('item-' + itemId)?.remove()
            updateCartBadge(data.cartCount)
            checkEmptyCart()
            showToast('Item removed from cart')
          } else {
            // update qty display
            const qtyEl = document.getElementById('qty-' + itemId)
            if (qtyEl) qtyEl.textContent = data.newQty
            updateCartBadge(data.cartCount)
            // reload to recalculate total accurately
            setTimeout(() => location.reload(), 400)
          }
        } else {
          showToast(data.message || 'Could not update', 'error')
        }
      })
      .catch(() => showToast('Something went wrong', 'error'))
    }

    // ── Remove item ──
    function removeItem(itemId) {
      fetch('/cart/remove/' + itemId, {
        method:  'DELETE',
        headers: { 'Content-Type': 'application/json' }
      })
      .then(r => r.json())
      .then(data => {
        if (data.success) {
          const el = document.getElementById('item-' + itemId)
          if (el) {
            el.style.transition = 'opacity .3s, transform .3s'
            el.style.opacity    = '0'
            el.style.transform  = 'translateX(20px)'
            setTimeout(() => { el.remove(); checkEmptyCart() }, 300)
          }
          updateCartBadge(data.cartCount)
          showToast('Item removed')
          setTimeout(() => location.reload(), 600)
        } else {
          showToast(data.message || 'Could not remove', 'error')
        }
      })
      .catch(() => showToast('Something went wrong', 'error'))
    }

    // ── Update navbar cart badge ──
    function updateCartBadge(count) {
      const badge = document.getElementById('cartCount')
      if (badge) badge.textContent = count || 0
    }

    // ── Check if cart is now empty and reload ──
    function checkEmptyCart() {
      const remaining = document.querySelectorAll('.cart-item')
      if (remaining.length === 0) {
        setTimeout(() => location.reload(), 400)
      }
    }
  </script>
</body>
</html>
