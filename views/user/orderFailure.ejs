<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Payment Failed | Blushberry</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #fdf6f8; --surface: #ffffff; --surface2: #fef0f4;
      --border: #f0dde4; --accent: #c2185b; --accent-dim: #e91e8c;
      --text: #1a0a10; --muted: #8a6d74;
      --display: 'Playfair Display', Georgia, serif;
      --body: 'DM Sans', sans-serif;
    }
    body {
      background: var(--bg);
      font-family: var(--body);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 2rem;
    }

    .fail-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 3rem 2.5rem;
      text-align: center;
      max-width: 480px;
      width: 100%;
      box-shadow: 0 4px 32px rgba(194, 24, 91, 0.08);
    }

    .fail-icon-wrap {
      width: 90px;
      height: 90px;
      background: rgba(224, 108, 108, 0.1);
      border: 2px solid rgba(224, 108, 108, 0.25);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 1.5rem;
      font-size: 2.2rem;
    }

    .fail-title {
      font-family: var(--display);
      font-size: 1.8rem;
      font-weight: 700;
      color: #c0392b;
      margin-bottom: 0.5rem;
    }

    .fail-subtitle {
      font-size: 0.9rem;
      color: var(--muted);
      margin-bottom: 1.5rem;
      line-height: 1.6;
    }

    .reason-box {
      background: rgba(224, 108, 108, 0.07);
      border: 1px solid rgba(224, 108, 108, 0.2);
      border-radius: 10px;
      padding: 0.75rem 1rem;
      font-size: 0.82rem;
      color: #c0392b;
      margin-bottom: 1.75rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      text-align: left;
    }

    .btn-row {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      padding: 0.85rem 1.5rem;
      border-radius: 10px;
      font-family: var(--body);
      font-size: 0.92rem;
      font-weight: 500;
      cursor: pointer;
      text-decoration: none;
      transition: all 0.2s;
      border: none;
    }

    .btn-primary {
      background: linear-gradient(135deg, var(--accent), var(--accent-dim));
      color: #fff;
    }
    .btn-primary:hover {
      transform: translateY(-1px);
      box-shadow: 0 4px 20px rgba(194, 24, 91, 0.3);
    }

    .btn-secondary {
      background: none;
      border: 1.5px solid var(--border);
      color: var(--muted);
    }
    .btn-secondary:hover {
      border-color: var(--accent);
      color: var(--accent);
    }

    .secure-note {
      margin-top: 1.25rem;
      font-size: 0.72rem;
      color: var(--muted);
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.4rem;
    }

    .brand {
      font-family: var(--display);
      font-size: 1.3rem;
      font-weight: 700;
      color: var(--accent);
      text-decoration: none;
      margin-bottom: 2rem;
      display: inline-block;
    }
  </style>
</head>
<body>

  <a href="/" class="brand">Blushberry</a>

  <div class="fail-card">
    <div class="fail-icon-wrap">💔</div>

    <h1 class="fail-title">Payment Failed</h1>
    <p class="fail-subtitle">
      We couldn't process your payment.<br/>
      <strong>No amount has been charged</strong> to your account.
    </p>

    <% if (locals.reason) { %>
      <div class="reason-box">
        <i class="fas fa-exclamation-circle"></i>
        <span><%= reason %></span>
      </div>
    <% } %>

    <div class="btn-row">
      <a href="/checkout" class="btn btn-primary">
        <i class="fas fa-redo"></i> Retry Payment
      </a>
      <a href="/products" class="btn btn-secondary">
        <i class="fas fa-shopping-bag"></i> Continue Shopping
      </a>
    </div>

    <div class="secure-note">
      <i class="fas fa-shield-alt"></i> Your payment info is safe & secure
    </div>
  </div>

</body>
</html>