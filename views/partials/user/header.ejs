<nav style="position:sticky;top:0;z-index:1000;background:#fff;border-bottom:1px solid #f2e6e9;padding:0 48px;height:60px;display:flex;align-items:center;justify-content:space-between;box-shadow:0 2px 12px rgba(0,0,0,0.04);">

  <!-- Logo -->
  <a href="/" style="font-family:'Playfair Display',serif;font-size:22px;font-weight:900;color:#c0415a;letter-spacing:-0.5px;">
    Blush<span style="color:#1a1a2e;">Berry</span>
  </a>

  <!-- Nav Links -->
  <ul style="list-style:none;display:flex;gap:36px;align-items:center;">
    <li><a href="/" class="nav-link" style="font-size:13px;font-weight:500;color:#c0415a;">Home</a></li>
    <li><a href="#shop" class="nav-link" style="font-size:13px;font-weight:400;color:#555;">Shop</a></li>
    <li><a href="/order" class="nav-link" style="font-size:13px;font-weight:400;color:#555;">Order</a></li>
    <li><a href="/contact" class="nav-link" style="font-size:13px;font-weight:400;color:#555;">Contact</a></li>

    <% if (!user) { %>

      <!-- NOT LOGGED IN: Login button -->
      <li>
        <a href="/login" style="display:flex;align-items:center;gap:6px;text-decoration:none;background:#c0415a;color:#fff;padding:8px 18px;border-radius:20px;font-size:13px;font-weight:600;font-family:'Poppins',sans-serif;">
          <svg width="15" height="15" fill="none" stroke="#fff" stroke-width="2" viewBox="0 0 24 24">
            <circle cx="12" cy="8" r="4"/>
            <path d="M6 20c0-3.33 5.33-5 6-5s6 1.67 6 5"/>
          </svg>
          Login
        </a>
      </li>

    <% } else { %>

      <!-- LOGGED IN: SVG avatar + first name + dropdown -->
      <li style="position:relative;">

        <button id="profileBtn" style="background:none;border:none;cursor:pointer;padding:0;display:flex;align-items:center;gap:8px;">
          <!-- Profile photo or SVG fallback -->
          <% if (user.profilePhoto) { %>
            <img
              src="<%= user.profilePhoto.replace('s96-c', 's200-c') %>"
              alt="Profile"
             
              style="width:34px;height:34px;min-width:34px;min-height:34px;border-radius:50%;object-fit:cover;object-position:center;border:2px solid #e8c8d0;flex-shrink:0;display:block;"
            >
          <% } else { %>
            <div style="width:34px;height:34px;border-radius:50%;background:#f0e6e9;border:2px solid #e8c8d0;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
              <svg width="18" height="18" fill="none" stroke="#c0415a" stroke-width="2" viewBox="0 0 24 24">
                <circle cx="12" cy="8" r="4"/>
                <path d="M6 20c0-3.33 5.33-5 6-5s6 1.67 6 5"/>
              </svg>
            </div>
          <% } %>
          <!-- First name -->
          <span style="font-size:13px;font-weight:600;color:#1a1a2e;font-family:'Poppins',sans-serif;">
            <%= user.fullName ? user.fullName.split(' ')[0] : (user.name ? user.name.split(' ')[0] : 'Account') %>
          </span>
          <!-- Chevron -->
          <svg width="12" height="12" fill="none" stroke="#888" stroke-width="2.5" viewBox="0 0 24 24">
            <path d="M6 9l6 6 6-6"/>
          </svg>
        </button>

        <!-- Dropdown -->
        <ul id="profileDropdown" style="display:none;position:absolute;top:44px;right:0;background:#fff;border:1px solid #eee;border-radius:8px;box-shadow:0 4px 16px rgba(0,0,0,0.1);list-style:none;padding:8px 0;min-width:140px;z-index:100;">
          <li>
            <a href="/profile" style="display:flex;align-items:center;gap:8px;padding:9px 16px;font-size:13px;color:#555;font-family:'Poppins',sans-serif;text-decoration:none;">
              <svg width="14" height="14" fill="none" stroke="#888" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M6 20c0-3.33 5.33-5 6-5s6 1.67 6 5"/></svg>
              My Profile
            </a>
          </li>
          <li>
            <a href="/orders" style="display:flex;align-items:center;gap:8px;padding:9px 16px;font-size:13px;color:#555;font-family:'Poppins',sans-serif;text-decoration:none;">
              <svg width="14" height="14" fill="none" stroke="#888" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
              My Orders
            </a>
          </li>
          <li style="border-top:1px solid #f5e8ec;margin-top:4px;padding-top:4px;">
            <a href="/logout" style="display:flex;align-items:center;gap:8px;padding:9px 16px;font-size:13px;color:#c0415a;font-weight:600;font-family:'Poppins',sans-serif;text-decoration:none;">
              <svg width="14" height="14" fill="none" stroke="#c0415a" stroke-width="2" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9"/></svg>
              Log out
            </a>
          </li>
        </ul>

      </li>
    <% } %>
  </ul>
</nav>
<script>
    var profileBtn = document.getElementById('profileBtn');
  var profileDropdown = document.getElementById('profileDropdown');

  if (profileBtn && profileDropdown) {

    profileBtn.addEventListener('click', function (e) {
      e.stopPropagation();
      if (profileDropdown.style.display === 'block') { 
        profileDropdown.style.display = 'none';
      } else {
        profileDropdown.style.display = 'block';
      }
    });

    document.addEventListener('click', function (e) {
      if (!profileBtn.contains(e.target) && !profileDropdown.contains(e.target)) {
        profileDropdown.style.display = 'none';
      }
    });

  }
</script>